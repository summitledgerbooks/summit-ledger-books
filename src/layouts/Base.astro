---
import { Image } from "astro:assets";
import SEO from "../components/SEO.astro";
import "../styles/global.css";
import mtnLogo from "../assets/images/mtn-logo.png";
import footerLogo from "../assets/images/logo.png";
import badgeQboLevel2 from "../assets/images/badge-qbo-level-2.png";
import badgeQboPayroll from "../assets/images/badge-qbo-payroll.png";
import bookCert from "../assets/images/book-cert.png";
import clientCert from "../assets/images/client-cert.png";

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
}

const { title, description, ogType } = Astro.props;
const pathname = Astro.url.pathname;
const path = pathname === "/" ? "/" : pathname.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <SEO title={title} description={description} ogType={ogType} />
    <link rel="preconnect" href="https://calendly.com" />
    <link rel="preconnect" href="https://assets.calendly.com" />
    <link rel="dns-prefetch" href="https://calendly.com" />
    <link rel="dns-prefetch" href="https://assets.calendly.com" />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-ERKMFNNSXR" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-ERKMFNNSXR');
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="logo">
          <Image src={mtnLogo} style="width: 50px; height: 50px;" alt="" />
          <span class="logo-text">Summit Ledger <span class="logo-text-sub">Books</span></span>
        </a>
        <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">&#9776;</button>
        <ul class="site-nav">
          <li><a href="/" aria-current={path === "/" ? "page" : undefined}>Home</a></li>
          <li><a href="/about" aria-current={path === "/about" ? "page" : undefined}>About</a></li>
          <li><a href="/services" aria-current={path === "/services" ? "page" : undefined}>Services</a></li>
          <li><a href="/pricing" aria-current={path === "/pricing" ? "page" : undefined}>Pricing</a></li>
          <li><a href="/faq" aria-current={path === "/faq" ? "page" : undefined}>FAQ</a></li>
          <li><a href="/blog" aria-current={path.startsWith("/blog") ? "page" : undefined}>Blog</a></li>
          <li><a href="/contact" aria-current={path === "/contact" ? "page" : undefined}>Contact</a></li>
        </ul>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a href="/" class="logo">
              <Image src={footerLogo} alt="Summit Ledger Books" />
            </a>
            <p class="footer-tagline">Every investor is on a climb. We take the books off your back so you can reach the top.</p>
            <div class="badge-row badge-row--footer">
              <Image src={badgeQboLevel2} alt="QuickBooks Online Certified" class="badge-img" />
              <Image src={badgeQboPayroll} alt="QuickBooks Payroll Certified" class="badge-img" />
              <Image src={bookCert} alt="Bookkeeping Certified" class="badge-img" />
              <Image src={clientCert} alt="QuickBooks Client Certified" class="badge-img" />
            </div>
          </div>

          <div class="footer-links">
            <p class="footer-heading">Navigation</p>
            <ul class="footer-nav">
              <li><a href="/about">About</a></li>
              <li><a href="/services">Services</a></li>
              <li><a href="/pricing">Pricing</a></li>
              <li><a href="/faq">FAQ</a></li>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/contact">Contact</a></li>
            </ul>
          </div>

          <div class="footer-contact">
            <p class="footer-heading">Get in touch</p>
            <p class="footer-contact-item"><a href="mailto:austin@summitledgerbooks.com">austin@summitledgerbooks.com</a></p>
            <p class="footer-contact-item"><a href="tel:+13854502276">385-450-2276</a></p>
            <p class="footer-contact-item">
              <a href="https://www.linkedin.com/in/summitledgerbooks/" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 0.4rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                Connect on LinkedIn
              </a>
            </p>
            <div class="footer-cta">
              <p style="font-size: 0.875rem; margin-bottom: var(--space-sm);">Ready to get organized?</p>
              <a href="https://calendly.com/summit-ledger-books/consultation" class="btn btn-primary">Book a Free Call</a>
            </div>
          </div>
        </div>

        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} Summit Ledger Books. All rights reserved. &nbsp;·&nbsp; <a href="/privacy">Privacy Policy</a></p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector(".nav-toggle");
      const nav = document.querySelector(".site-nav");
      if (toggle && nav) {
        toggle.addEventListener("click", () => {
          const expanded = nav.classList.toggle("open");
          toggle.setAttribute("aria-expanded", String(expanded));
        });
      }
    </script>
  </body>
</html>
