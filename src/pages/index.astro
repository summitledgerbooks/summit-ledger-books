---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Summit Ledger Books",
  "description": "Professional bookkeeping for real estate investors, property managers, and developers. We track rental income, property expenses, and portfolio performance across every entity and property you own.",
  "url": "https://summitledgerbooks.com",
  "telephone": "+13854502276",
  "email": "austin@summitledgerbooks.com",
  "areaServed": {
    "@type": "Country",
    "name": "United States"
  },
  "serviceType": "Bookkeeping",
  "priceRange": "$$",
  "sameAs": [
    "https://www.linkedin.com/in/summitledgerbooks/"
  ]
};
---

<Base description="Real estate bookkeeping for investors, property managers, and developers. Books closed by the 10th, every property, every entity, every month. Summit Ledger Books.">
  <section class="hero">
    <div class="container">
      <h1>Bookkeeping Built for Real Estate Investors</h1>
      <p class="hero-tagline">We handle the books. You focus on the summit.</p>
      <p>We give you property-level profit, clean entity separation, and monthly reports you can actually use to make decisions.</p>
      <a href="https://calendly.com/summit-ledger-books/consultation" class="btn btn-hero">Book a Free Call</a>
    </div>
  </section>

  <!-- Problem -->
  <section class="container section-block">
    <h2 class="section-heading" style="text-align: center;">Rental bookkeeping gets messy fast.</h2>
    <img
      src="/assets/real-estate-bookkeeping.jpg"
      alt="Real estate bookkeeping services for investors and property managers"
      width="800"
      height="400"
      loading="eager"
      style="border-radius: var(--radius-md); margin-bottom: var(--space-lg); width: 100%; height: auto; object-fit: cover; max-height: 18rem;"
    />
    <div class="two-col-section">
      <ul class="problem-list">
        <li>Personal and rental expenses mixed together</li>
        <li>No visibility into profit by property</li>
        <li>Bank balances that don't match QuickBooks</li>
        <li>Scrambling to pull records together at tax time</li>
        <li>No clear picture of actual cash flow</li>
      </ul>
      <p class="section-prose">Inconsistent bookkeeping creates stress and leads to poor decisions. When your records are behind, disorganized, or inaccurate, you're flying blind on your own portfolio.</p>
    </div>
  </section>

  <!-- Outcome -->
  <section class="outcome-band">
    <div class="container">
      <h2 class="section-heading" style="text-align: center; color: var(--color-navy);">What changes when your books are clean.</h2>
      <div class="two-col-section">
        <ul class="outcome-list">
          <li>Accurate monthly profit by property</li>
          <li>Reliable cash flow visibility</li>
          <li>Clean reconciliations every month</li>
          <li>Clear owner draw tracking</li>
          <li>CPA-ready reports at tax time</li>
        </ul>
        <p class="section-prose">When your books are current and accurate, you can make confident decisions about your portfolio. You know what's performing, what isn't, and where your money is actually going. See how our <a href="/services" style="color: var(--color-navy); text-decoration: underline;">real estate bookkeeping services</a> keep your portfolio organized.</p>
      </div>
    </div>
  </section>

  <!-- What We Handle -->
  <section class="container section-block">
    <h2 class="section-heading" style="text-align: center;">What We Handle</h2>
    <div class="card-grid">
      <a href="/services/portfolio-bookkeeping" class="card card-link">
        <h3>Rental Property Bookkeeping</h3>
        <p>Track rental income and expenses across every property and entity. We categorize transactions, reconcile accounts, and deliver clear monthly statements for your entire portfolio.</p>
        <span class="card-arrow">Learn more &rarr;</span>
      </a>
      <a href="/services/catch-up-bookkeeping" class="card card-link">
        <h3>Catch-Up Bookkeeping</h3>
        <p>Behind on your property records? We'll work through your backlog, whether it's a few months or a few years, and bring everything current.</p>
        <span class="card-arrow">Learn more &rarr;</span>
      </a>
      <a href="/services/tax-prep-support" class="card card-link">
        <h3>Tax Preparation Support</h3>
        <p>We organize your real estate financials and work with your CPA on Schedule E filings, depreciation schedules, and entity-level reporting so tax season runs smoothly.</p>
        <span class="card-arrow">Learn more &rarr;</span>
      </a>
      <a href="/services/property-management-accounting" class="card card-link">
        <h3>Property Management Accounting</h3>
        <p>We track management fees, owner disbursements, and trust accounting separately so your books reflect how property management actually works. Rent roll reconciliation included.</p>
        <span class="card-arrow">Learn more &rarr;</span>
      </a>
      <a href="/services/development-project-tracking" class="card card-link">
        <h3>Development Project Tracking</h3>
        <p>We track hard costs, soft costs, land, and carrying costs by project. Draw schedules, construction loan reconciliation, and cost-to-complete reporting so you always know where your money is going.</p>
        <span class="card-arrow">Learn more &rarr;</span>
      </a>
      <a href="/services/portfolio-bookkeeping" class="card card-link">
        <h3>Multi-Entity Bookkeeping</h3>
        <p>Separate ledgers for each LLC or entity, with consolidated reporting across your entire portfolio. Whether you have two entities or twenty, we keep every set of books clean and audit-ready.</p>
        <span class="card-arrow">Learn more &rarr;</span>
      </a>
    </div>
    <p style="text-align: center; margin-top: var(--space-lg);"><a href="/services">View all services &rarr;</a></p>
  </section>

  <!-- What You Get Each Month -->
  <section class="container section-block">
    <h2 class="section-heading" style="text-align: center;">What You Get Each Month</h2>
    <div class="deliverables-grid">
      <div class="deliverable-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Bank and credit card reconciliations</span>
      </div>
      <div class="deliverable-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Organized chart of accounts</span>
      </div>
      <div class="deliverable-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Property-level income and expense tracking</span>
      </div>
      <div class="deliverable-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Monthly profit and loss statement and balance sheet</span>
      </div>
      <div class="deliverable-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Owner snapshot summary</span>
      </div>
      <div class="deliverable-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Clear list of questions or items needing your review</span>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="container section-block">
    <h2 class="section-heading" style="text-align: center;">How It Works</h2>
    <div class="steps">
      <div class="step">
        <div>
          <h3>Schedule a Consultation</h3>
          <p>We start with a free call to understand your portfolio structure and bookkeeping needs.</p>
        </div>
      </div>
      <div class="step">
        <div>
          <h3>We Get to Work</h3>
          <p>We connect to your accounts and organize income, expenses, and transactions across all your properties and entities.</p>
        </div>
      </div>
      <div class="step">
        <div>
          <h3>You Get Answers</h3>
          <p>Receive monthly reports and real-time insight into your portfolio's financial performance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Summit Ledger -->
  <section class="why-band">
    <div class="container">
      <h2 class="section-heading" style="text-align: center; color: var(--color-navy);">Why Summit Ledger Books</h2>
      <p style="text-align: center; color: var(--color-text-muted); margin-bottom: var(--space-lg); max-width: 38rem; margin-left: auto; margin-right: auto;">Real estate investing is a climb. We make sure your books never slow you down. <a href="/about" style="color: var(--color-navy);">Learn more about who we are.</a></p>
      <div class="why-grid">
        <div class="why-item">
          <h3>Small firm, direct communication</h3>
          <p>You work directly with your bookkeeper, not a rotating support team. One person who knows your portfolio.</p>
        </div>
        <div class="why-item">
          <h3>Structured monthly rhythm</h3>
          <p>Books closed by the 10th, every month, without reminders. You know exactly when to expect your reports.</p>
        </div>
        <div class="why-item">
          <h3>QuickBooks Online focus</h3>
          <p>We build clean, organized QuickBooks files your CPA can work from directly, with no cleanup required on their end.</p>
        </div>
        <div class="why-item">
          <h3>Real estate niche specialization</h3>
          <p>We work exclusively with real estate investors and property managers. We know the accounts, the schedules, and the reporting that matters for your business.</p>
        </div>
        <div class="why-item">
          <h3>Financial planning, in-house</h3>
          <p>Through our partnership with Transamerica Financial Advisors, we can connect you with financial planning services alongside your bookkeeping, so your numbers and your long-term goals stay aligned.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="container section-block">
    <h2 class="section-heading" style="text-align: center;">What clients say</h2>
    <div class="testimonial-grid">
      <div class="testimonial-card">
        <div class="testimonial-stars">★★★★★</div>
        <blockquote class="testimonial-quote">"It'd be hard to find someone with a higher work ethic than Austin! He is genuine, consistent, growth-oriented, selfless, and serviceable. You will not regret working with Austin!"</blockquote>
        <div class="testimonial-author">Anna P.</div>
      </div>
      <div class="testimonial-card">
        <div class="testimonial-stars">★★★★★</div>
        <blockquote class="testimonial-quote">"Can't say enough good things! They will take a lot of stress off your plate."</blockquote>
        <div class="testimonial-author">James Millward</div>
      </div>
      <div class="testimonial-card">
        <div class="testimonial-stars">★★★★★</div>
        <blockquote class="testimonial-quote">"You couldn't ask for a more professional, personable, honest, and straight-forward guy to work with!"</blockquote>
        <div class="testimonial-author">Emma Andreasen</div>
      </div>
      <div class="testimonial-card">
        <div class="testimonial-stars">★★★★★</div>
        <blockquote class="testimonial-quote">"I have known the owner for years. He is professional, efficient, and dependable. Would recommend working with him in any capacity."</blockquote>
        <div class="testimonial-author">Jason Adams</div>
      </div>
    </div>
  </section>

  <!-- From Our Blog -->
  <section class="container section-block">
    <h2 class="section-heading" style="text-align: center;">From Our Blog</h2>
    <p style="text-align: center; color: var(--color-text-muted); margin-bottom: var(--space-lg);">Practical guidance on real estate bookkeeping, tax preparation, and portfolio management.</p>
    <div class="card-grid">
      {recentPosts.map((post) => (
        <a href={`/blog/${post.id}`} class="card card-link">
          <h3 style="font-size: 1.05rem;">{post.data.title}</h3>
          <p>{post.data.description}</p>
          <span class="card-arrow">Read more &rarr;</span>
        </a>
      ))}
    </div>
    <p style="text-align: center; margin-top: var(--space-lg);"><a href="/blog">View all posts &rarr;</a></p>
  </section>

  <!-- Final CTA -->
  <section class="container" style="text-align: center; padding-bottom: var(--space-xl);">
    <h2 class="section-heading">Ready to get your real estate books in order?</h2>
    <p style="color: var(--color-text-muted); margin-bottom: var(--space-lg);">Let's talk about how Summit Ledger Books can help your portfolio run more efficiently.</p>
    <a href="/contact" class="btn btn-primary">Book a Free Call</a>
  </section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
</Base>
