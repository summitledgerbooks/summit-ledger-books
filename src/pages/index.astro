---
import Base from "../layouts/Base.astro";
---

<Base>
  <section class="hero">
    <div class="container">
      <h1>Bookkeeping that lets you focus on your business</h1>
      <p>Summit Ledger Books provides accurate, reliable bookkeeping services for small businesses. We handle the numbers so you can focus on growth.</p>
      <a href="https://calendly.com/summit-ledger-books/consultation" class="btn btn-hero">Get Started</a>
    </div>
  </section>

  <section class="container" style="padding-bottom: var(--space-xl);">
    <h2 class="section-heading" style="text-align: center;">Our Services</h2>
    <div class="card-grid">
      <div class="card">
        <h3>Monthly Bookkeeping</h3>
        <p>Consistent, accurate record-keeping every month. We categorize transactions, reconcile accounts, and deliver clear financial reports.</p>
      </div>
      <div class="card">
        <h3>Catch-Up Bookkeeping</h3>
        <p>Behind on your books? We'll get your records current and organized so you can move forward with confidence.</p>
      </div>
      <div class="card">
        <h3>Tax Preparation Support</h3>
        <p>We organize your financial records and work with your CPA to make tax season smooth and stress-free.</p>
      </div>
    </div>
  </section>

  <section class="container" style="padding-bottom: var(--space-xl);">
    <h2 class="section-heading" style="text-align: center;">How It Works</h2>
    <div class="steps">
      <div class="step">
        <div>
          <h3>Schedule a Consultation</h3>
          <p>We start with a free call to understand your business and bookkeeping needs.</p>
        </div>
      </div>
      <div class="step">
        <div>
          <h3>We Get to Work</h3>
          <p>Our team connects to your accounts and begins organizing your financial records.</p>
        </div>
      </div>
      <div class="step">
        <div>
          <h3>You Get Clarity</h3>
          <p>Receive monthly reports and real-time insight into your business finances.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container" style="text-align: center; padding-bottom: var(--space-xl);">
    <h2 class="section-heading">Ready to get your books in order?</h2>
    <p style="color: var(--color-text-muted); margin-bottom: var(--space-lg);">Let's talk about how Summit Ledger Books can help your business thrive.</p>
    <a href="https://calendly.com/summit-ledger-books/consultation" class="btn btn-primary">Book a Free Call</a>
  </section>
</Base>
