---
import Base from "../layouts/Base.astro";
---

<Base title="Services" description="Explore our bookkeeping services including monthly bookkeeping, catch-up bookkeeping, payroll support, and tax preparation.">
  <div class="container">
    <h1 class="section-heading">Our Services</h1>
    <p style="color: var(--color-text-muted); margin-bottom: var(--space-xl); max-width: 42rem;">We offer a full range of bookkeeping services designed to keep your finances organized and your business on track.</p>

    <div class="card-grid">
      <div class="card">
        <h3>Monthly Bookkeeping</h3>
        <p>We handle your day-to-day bookkeeping so your records are always current. This includes transaction categorization, bank and credit card reconciliation, and monthly financial statements.</p>
      </div>
      <div class="card">
        <h3>Catch-Up Bookkeeping</h3>
        <p>Fallen behind on your books? We'll work through your backlog — whether it's a few months or a few years — and bring everything current.</p>
      </div>
      <div class="card">
        <h3>Tax Preparation Support</h3>
        <p>We organize your financial records and prepare the reports your CPA needs. No more scrambling at tax time.</p>
      </div>
      <div class="card">
        <h3>Accounts Payable &amp; Receivable</h3>
        <p>Stay on top of what you owe and what you're owed. We manage invoicing, bill payments, and aging reports.</p>
      </div>
      <div class="card">
        <h3>Payroll Support</h3>
        <p>We help process payroll, track employee hours, and ensure your payroll taxes are calculated correctly.</p>
      </div>
      <div class="card">
        <h3>Financial Reporting</h3>
        <p>Get clear, easy-to-read reports including profit &amp; loss statements, balance sheets, and cash flow summaries delivered monthly.</p>
      </div>
    </div>

    <div style="text-align: center; margin-top: var(--space-xl);">
      <a href="/contact" class="btn btn-primary">Request a Free Consultation</a>
    </div>
  </div>
</Base>
