---
import Base from "../layouts/Base.astro";
---

<Base title="Contact" description="Get in touch with Summit Ledger Co. for a free bookkeeping consultation.">
  <div class="container">
    <h1 class="section-heading">Contact Us</h1>
    <p style="color: var(--color-text-muted); margin-bottom: var(--space-xl); max-width: 42rem;">Have questions or ready to get started? Fill out the form below and we'll get back to you within one business day.</p>

    <form name="contact" method="POST" data-netlify="true" style="max-width: 36rem;">
      <input type="hidden" name="form-name" value="contact" />

      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required />
      </div>

      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required />
      </div>

      <div class="form-group">
        <label for="business">Business Name</label>
        <input type="text" id="business" name="business" />
      </div>

      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" required></textarea>
      </div>

      <button type="submit" class="btn btn-primary">Send Message</button>
    </form>
  </div>
</Base>
