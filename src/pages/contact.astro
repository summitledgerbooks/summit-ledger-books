---
import Base from "../layouts/Base.astro";

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPoint",
  "contactType": "customer service",
  "telephone": "+13854502276",
  "email": "austin@summitledgerbooks.com",
  "availableLanguage": "English",
  "url": "https://summitledgerbooks.com/contact"
};
---

<Base title="Contact" description="Get in touch with Summit Ledger Books for a free bookkeeping consultation.">
  <div class="container">
    <h1 class="section-heading">Let's Get Your Books Clean.</h1>
    <p style="color: var(--color-text-muted); margin-bottom: var(--space-xl); max-width: 42rem;">On the call, we'll go over your current setup, what's working, and what isn't. You'll walk away with a clear picture of what getting organized actually looks like for your portfolio, whether or not we end up working together. Looking for details first? Check out our <a href="/services">services</a> or <a href="/pricing">pricing</a>.</p>

    <div class="contact-grid">
      <div class="contact-calendly">
        <h2 style="font-size: 1.125rem; font-weight: 700; color: var(--color-navy); margin-bottom: var(--space-md);">Book a time</h2>
        <div class="calendly-inline-widget" data-url="https://calendly.com/summit-ledger-books/consultation" style="min-width: 280px; height: 1050px;"></div>
        <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
      </div>

      <div class="contact-form-col">
        <h2 style="font-size: 1.125rem; font-weight: 700; color: var(--color-navy); margin-bottom: var(--space-sm);">Send a message</h2>
        <p style="color: var(--color-text-muted); font-size: 0.9375rem; margin-bottom: var(--space-lg);">Prefer to reach out by form? We'll get back to you within one business day.</p>

        <form name="contact" method="POST" data-netlify="true">
          <input type="hidden" name="form-name" value="contact" />

          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required />
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required />
          </div>

          <div class="form-group">
            <label for="business">Business Name</label>
            <input type="text" id="business" name="business" />
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" required></textarea>
          </div>

          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
      </div>
    </div>
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(contactSchema)} />
</Base>
