---
import Base from "../layouts/Base.astro";

const localSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Summit Ledger Books",
  "description": "Real estate bookkeeping services for investors, property managers, and developers in Davis County, Utah. Based in Kaysville.",
  "url": "https://summitledgerbooks.com/bookkeeping-davis-county",
  "telephone": "+13854502276",
  "email": "austin@summitledgerbooks.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Kaysville",
    "addressRegion": "UT",
    "addressCountry": "US"
  },
  "areaServed": [
    {
      "@type": "AdministrativeArea",
      "name": "Davis County, Utah"
    }
  ],
  "serviceType": "Bookkeeping",
  "priceRange": "$$",
  "sameAs": [
    "https://www.linkedin.com/in/summitledgerbooks/"
  ]
};
---

<Base title="Bookkeeping in Davis County, Utah" description="Real estate bookkeeping for investors, landlords, and property managers in Davis County, Utah. Based in Kaysville. Monthly bookkeeping, catch-up services, and tax prep support.">
  <section class="hero">
    <div class="container">
      <h1>Real Estate Bookkeeping in Davis County, Utah</h1>
      <p class="hero-tagline">Based in Kaysville. Built for real estate investors.</p>
      <p>We help landlords, property managers, and developers across Davis County keep their books clean, accurate, and ready for tax season.</p>
      <a href="/contact" class="btn btn-hero">Book a Free Call</a>
    </div>
  </section>

  <section class="container section-block">
    <div class="two-col-section">
      <div>
        <h2 class="section-heading">Local Bookkeeping for Davis County Investors</h2>
        <p>Summit Ledger Books is based in Kaysville and works with real estate investors throughout Davis County, including Layton, Bountiful, Farmington, Centerville, Clearfield, Syracuse, and Clinton. We understand the local rental market and the financial complexity that comes with managing properties along the Wasatch Front.</p>
        <p>Whether you own a handful of rental properties in Layton or manage a portfolio of units across Bountiful and Farmington, our <a href="/services">bookkeeping services</a> are built for how real estate investors actually operate.</p>
      </div>
      <div>
        <img
          src="/assets/davis-county-bookkeeping.jpg"
          alt="Bookkeeping services in Davis County, Utah for real estate investors"
          width="600"
          height="400"
          loading="eager"
          style="border-radius: var(--radius-md); width: 100%; height: auto; object-fit: cover;"
        />
      </div>
    </div>
  </section>

  <section class="outcome-band">
    <div class="container">
      <h2 class="section-heading" style="text-align: center; color: var(--color-navy);">What We Handle for Davis County Clients</h2>
      <div class="card-grid" style="margin-top: var(--space-lg);">
        <a href="/services/portfolio-bookkeeping" class="card card-link">
          <h3>Rental Property Bookkeeping</h3>
          <p>Monthly reconciliations, transaction categorization, and property-level financial statements for your entire portfolio.</p>
          <span class="card-arrow">Learn more &rarr;</span>
        </a>
        <a href="/services/catch-up-bookkeeping" class="card card-link">
          <h3>Catch-Up Bookkeeping</h3>
          <p>Behind on your records? We'll work through months or years of backlog and bring everything current.</p>
          <span class="card-arrow">Learn more &rarr;</span>
        </a>
        <a href="/services/property-management-accounting" class="card card-link">
          <h3>Property Management Accounting</h3>
          <p>Trust accounting, owner disbursements, rent roll reconciliation, and management fee tracking.</p>
          <span class="card-arrow">Learn more &rarr;</span>
        </a>
        <a href="/services/tax-prep-support" class="card card-link">
          <h3>Tax Preparation Support</h3>
          <p>CPA-ready financials, Schedule E support, and depreciation schedules organized before tax season.</p>
          <span class="card-arrow">Learn more &rarr;</span>
        </a>
        <a href="/services/short-term-rental-bookkeeping" class="card card-link">
          <h3>Short-Term Rental Bookkeeping</h3>
          <p>Platform payout reconciliation, occupancy tax tracking, and property-level P&Ls for Airbnb and VRBO hosts.</p>
          <span class="card-arrow">Learn more &rarr;</span>
        </a>
        <a href="/services/financial-reporting" class="card card-link">
          <h3>Financial Reporting</h3>
          <p>Profit and loss by property, balance sheets, cash flow statements, and investor-ready reports delivered monthly.</p>
          <span class="card-arrow">Learn more &rarr;</span>
        </a>
      </div>
      <p style="text-align: center; margin-top: var(--space-lg);"><a href="/services">View all services &rarr;</a></p>
    </div>
  </section>

  <section class="container section-block">
    <h2 class="section-heading" style="text-align: center;">Why Davis County Investors Choose Us</h2>
    <div class="why-grid">
      <div class="why-item">
        <h3>Based in Kaysville</h3>
        <p>We're local. We know the Davis County rental market, the property tax cycle, and the communities our clients invest in. That context matters when categorizing expenses and understanding your portfolio.</p>
      </div>
      <div class="why-item">
        <h3>Real estate specialization</h3>
        <p>We don't do general small business bookkeeping. We work exclusively with real estate investors, property managers, and developers. Your books are set up for how real estate actually works.</p>
      </div>
      <div class="why-item">
        <h3>QuickBooks Online certified</h3>
        <p>Your books are maintained in QuickBooks Online so your CPA can work from them directly. No cleanup needed on their end at tax time.</p>
      </div>
      <div class="why-item">
        <h3>Books closed by the 10th</h3>
        <p>Every month, your books are reconciled and your financial statements are delivered by the 10th. No reminders needed, no delays.</p>
      </div>
    </div>
  </section>

  <section class="container section-block">
    <h2 class="section-heading" style="text-align: center;">Communities We Serve in Davis County</h2>
    <p style="text-align: center; color: var(--color-text-muted); max-width: 42rem; margin: 0 auto var(--space-lg);">We work with real estate investors and property managers throughout Davis County, including:</p>
    <div class="location-grid">
      <span class="location-tag">Kaysville</span>
      <span class="location-tag">Layton</span>
      <span class="location-tag">Bountiful</span>
      <span class="location-tag">Farmington</span>
      <span class="location-tag">Centerville</span>
      <span class="location-tag">Clearfield</span>
      <span class="location-tag">Syracuse</span>
      <span class="location-tag">Clinton</span>
      <span class="location-tag">Woods Cross</span>
      <span class="location-tag">North Salt Lake</span>
      <span class="location-tag">Fruit Heights</span>
      <span class="location-tag">West Point</span>
    </div>
  </section>

  <section class="container section-block">
    <h2 class="section-heading" style="text-align: center;">From Our Blog</h2>
    <p style="text-align: center; color: var(--color-text-muted); margin-bottom: var(--space-lg);">Practical guidance for real estate investors managing rental properties.</p>
    <div class="article-related-links" style="justify-content: center; gap: var(--space-lg); flex-wrap: wrap;">
      <a href="/blog/chart-of-accounts-rental-properties">How to Set Up a Chart of Accounts &rarr;</a>
      <a href="/blog/real-estate-bookkeeping-mistakes">5 Bookkeeping Mistakes Investors Make &rarr;</a>
      <a href="/blog/month-end-close-checklist">Month-End Close Checklist &rarr;</a>
    </div>
  </section>

  <section class="container" style="text-align: center; padding-bottom: var(--space-xl);">
    <h2 class="section-heading">Ready to get your books in order?</h2>
    <p style="color: var(--color-text-muted); margin-bottom: var(--space-lg);">Schedule a free consultation and we'll walk through your portfolio, your current bookkeeping setup, and what getting organized looks like.</p>
    <a href="/contact" class="btn btn-primary">Book a Free Call</a>
  </section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(localSchema)} />
</Base>
