---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "Summit Ledger Books",
    "url": "https://summitledgerbooks.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Summit Ledger Books",
    "url": "https://summitledgerbooks.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://summitledgerbooks.com/images/logo.png"
    }
  },
  "url": `https://summitledgerbooks.com/blog/${post.id}`,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://summitledgerbooks.com/blog/${post.id}`
  }
};
---

<Base title={post.data.title} description={post.data.description} ogType="article">
  <div class="article-header">
    <div class="container">
      <a href="/blog" class="article-back">&larr; Blog</a>
      <h1 class="article-title">{post.data.title}</h1>
      <div class="article-meta">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        {post.data.tags.length > 0 && (
          <div class="tag-list">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>

  <div class="container">
    <div class="prose article-prose">
      <Content />
    </div>

    <div class="article-related">
      <p class="article-related-label">Explore our services</p>
      <div class="article-related-links">
        <a href="/services">Real estate bookkeeping services &rarr;</a>
        <a href="/pricing">Monthly plans and pricing &rarr;</a>
      </div>
    </div>

    <div class="article-cta">
      <p>Want clean books for your real estate portfolio?</p>
      <a href="https://calendly.com/summit-ledger-books/consultation" class="btn btn-primary">Book a Free Call</a>
    </div>

    <div class="article-footer">
      <a href="/blog">&larr; Back to all posts</a>
    </div>
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</Base>
