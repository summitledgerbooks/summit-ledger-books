---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Blog" description="Real estate bookkeeping tips, rental property tax advice, and financial insights for investors, property managers, and developers from Summit Ledger Books.">
  <div class="container">
    <h1 class="section-heading">Blog</h1>

    <div class="post-list">
      {posts.map((post) => (
        <article class="post-card">
          <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
          <div class="post-meta">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
            </time>
          </div>
          {post.data.tags.length > 0 && (
            <div class="tag-list">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
          <p>{post.data.description}</p>
        </article>
      ))}
    </div>
  </div>
</Base>
